def run_timetree(name: str, out: str, extra_args: str):
  # Build output selection based on which outputs the extra_args actually support:
  #  - confidence requires --time-marginal or --confidence
  #  - gtr requires ancestral reconstruction (excluded with --branch-length-mode=input)
  outputs = ["nwk", "nexus", "auspice", "augur-node-data", "clock-model"]
  if "--branch-length-mode=input" not in extra_args:
    outputs.append("gtr")
  if "--time-marginal" in extra_args or "--confidence" in extra_args:
    outputs.append("confidence")
  selection = f"--output-selection={','.join(outputs)}"

  cmd = f"""
  {TREETIME_BIN} timetree
  --tree={DATA_DIR}/{name}/tree.nwk
  --dates={DATA_DIR}/{name}/metadata.tsv
  --aln={DATA_DIR}/{name}/aln.fasta.xz
  --output-all={RESULTS_DIR}/timetree/{out}
  {selection}
  {extra_args}
  """
  return run_batch_cmd(name, "timetree", cmd)


def init_worker():
  signal(SIGINT, SIG_IGN)


def get_timing(res: dict[str, str | int | float | Timing | None]) -> Timing:
  t = res.get("timing")
  return t if isinstance(t, Timing) else Timing(0, 0, 0)


def result_label(res: dict[str, str | int | float | Timing | None]) -> str:
  cmd_name = res["cmd_name"]
  data_name = res["data_name"]
  return f"{cmd_name} for {data_name}" if data_name else str(cmd_name)


def print_table(title: str, headers: list[str], rows: list[list[str]], color_fn=grey) -> None:
  if not rows:
    return
  widths = [max(len(h), max((len(r[i]) for r in rows), default=0)) for i, h in enumerate(headers)]
  total_width = sum(widths) + 3 * len(widths) + 1
  sep = "+" + "-" * (total_width - 2) + "+"
  col_sep = "+-" + "-+-".join("-" * w for w in widths) + "-+"
  header_row = "| " + " | ".join(h.ljust(w) for h, w in zip(headers, widths)) + " |"
  title_row = "| " + title.center(total_width - 4) + " |"
  print(sep)
  print(blue(title_row))
  print(col_sep)
  print(grey(header_row))
  print(col_sep)
  for row in rows:
    print(color_fn("| " + " | ".join(c.ljust(w) for c, w in zip(row, widths)) + " |"))
  print(col_sep)


def print_summary(results: list[dict[str, str | int | float | Timing | None]], wall_time: float, num_cores: int, skip_perf: bool = False) -> None:
  n = len(results)
  failures = [res for res in results if res["code"] != 0]
  successes = [res for res in results if res["code"] == 0]
  n_err = len(failures)
  n_ok = len(successes)

  if n == 0:
    print("No tests found")
    sys.exit(1)

  timings = [get_timing(res) for res in successes]
  walls = [t.wall for t in timings] if timings else [0.0]
  cpus = [t.cpu for t in timings] if timings else [0.0]

  sum_wall = sum(walls)
  sum_cpu = sum(cpus)
  max_wall = max(walls) if walls else 0

  print()

  # 1. Test Results
  f_color = red if n_err > 0 else green
  print_table(
    "TEST RESULTS",
    ["Outcome", "Count"],
    [
      ["Passed", str(n_ok)],
      ["Failed", str(n_err)],
      ["Total", str(n)],
    ],
    lambda x: green(x) if "Passed" in x and n_ok > 0 else (red(x) if "Failed" in x and n_err > 0 else grey(x))
  )
  print()

  # 2. Timing and Parallelism (skip if only_failures mode)
  if not skip_perf:
    if n_ok > 0:
      speedup = sum_wall / wall_time if wall_time > 0 else 0
      efficiency = (speedup / num_cores * 100) if num_cores > 0 else 0
      cpu_ratio = (sum_cpu / sum_wall * 100) if sum_wall > 0 else 0
      bottleneck_pct = (max_wall / wall_time * 100) if wall_time > 0 else 0

      print_table(
        "TIMING AND PARALLELISM (passed tests only)" if n_err > 0 else "TIMING AND PARALLELISM",
        ["Metric", "Value", "How Calculated"],
        [
          ["Script wall time", format_duration(wall_time), "Measured"],
          ["Sum of test wall times", format_duration(sum_wall), "Measured"],
          ["Sum of test CPU times", format_duration(sum_cpu), "Measured"],
          ["", "", ""],
          ["Shortest test", format_duration(min(walls)), "Measured"],
          ["Median test", format_duration(statistics.median(walls)), "Measured"],
          ["Longest test", format_duration(max_wall), "Measured"],
          ["", "", ""],
          ["CPU cores", str(num_cores), "Hardware"],
          ["Speedup", f"{speedup:.1f}x", "sum_test_wall / script_wall"],
          ["Efficiency", f"{efficiency:.0f}%", "speedup / cores"],
          ["CPU ratio", f"{cpu_ratio:.0f}%", "sum_cpu / sum_wall"],
          ["Bottleneck", f"{bottleneck_pct:.0f}%", "longest_test / script_wall"],
        ]
      )
    else:
      print_table(
        "TIMING",
        ["Metric", "Value"],
        [["Script wall time", format_duration(wall_time)]]
      )
    print()

  # 5. Results by Command Type
  def get_cmd_type(res: dict[str, str | int | float | Timing | None]) -> str:
    return str(res["cmd_name"]).split("-")[0]

  cmd_types = sorted(set(get_cmd_type(res) for res in results))
  cmd_passed = Counter(get_cmd_type(res) for res in successes)
  cmd_failed = Counter(get_cmd_type(res) for res in failures)
  cmd_total = Counter(get_cmd_type(res) for res in results)

  print_table(
    "RESULTS BY COMMAND TYPE",
    ["Command", "Passed", "Failed", "Total"],
    [[cmd, str(cmd_passed[cmd]), str(cmd_failed[cmd]), str(cmd_total[cmd])] for cmd in cmd_types]
  )
  print()

  # 6. Slowest Tests (skip if only_failures mode)
  if not skip_perf and n_ok > 0:
    sorted_by_wall = sorted(successes, key=lambda r: get_timing(r).wall, reverse=True)
    print_table(
      "TOP 10 SLOWEST TESTS",
      ["Wall Clock", "CPU Time", "CPU %", "Test Name"],
      [
        [
          format_duration(get_timing(res).wall),
          format_duration(get_timing(res).cpu),
          f"{(get_timing(res).cpu / get_timing(res).wall * 100) if get_timing(res).wall > 0 else 0:.0f}%",
          result_label(res)
        ]
        for res in sorted_by_wall[:10]
      ]
    )
    print()

  # 7. Most I/O Bound Tests (skip if only_failures mode)
  if not skip_perf and n_ok > 0:
    sorted_by_cpu_eff = sorted(
      [(res, get_timing(res).cpu / get_timing(res).wall if get_timing(res).wall > 0 else 0) for res in successes],
      key=lambda x: x[1]
    )
    io_bound = [(res, eff) for res, eff in sorted_by_cpu_eff if get_timing(res).wall > 0.1][:5]
    if io_bound:
      print_table(
        "MOST I/O BOUND TESTS (lowest CPU utilization)",
        ["CPU %", "Wall Clock", "Test Name"],
        [[f"{eff*100:.1f}%", format_duration(get_timing(res).wall), result_label(res)] for res, eff in io_bound]
      )
      print()

  if n_err > 0:
    failed_cmds = [""] + [str(failure["cmd"]) for failure in failures]
    print(red("Failed commands:" + "\n\n  ".join(failed_cmds) + "\n\n"))

  sys.exit(0 if n_err == 0 else 1)


if __name__ == "__main__":
  # Parse arguments (order-independent)
  flags = {a for a in sys.argv[1:] if a.startswith("--")}
  positional_args = [a for a in sys.argv[1:] if not a.startswith("--")]

  known_flags = {"--only-failures", "--no-stats"}
  unknown_flags = flags - known_flags
  if unknown_flags:
    sys.exit(f"Unknown flag(s): {', '.join(sorted(unknown_flags))}\nUsage: {sys.argv[0]} <path_to_treetime_executable> [--only-failures] [--no-stats]")

  if len(positional_args) != 1:
    sys.exit(f"Usage: {sys.argv[0]} <path_to_treetime_executable> [--only-failures]")

  only_failures = "--only-failures" in flags
  no_stats = "--no-stats" in flags


  def normpath(path: Path) -> str:
    return str(path.resolve())


  THIS_DIR = normpath(Path(__file__).parent)
  PROJECT_ROOT = normpath(Path(THIS_DIR) / '..')


  def relpath(path: Path) -> str:
    return os.path.relpath(normpath(path), PROJECT_ROOT)


  TREETIME_BIN = normpath(Path(positional_args[0]))
  DATA_DIR = relpath(Path(PROJECT_ROOT) / 'data')
  RESULTS_DIR = relpath(Path(PROJECT_ROOT) / 'tmp/smoke-tests')
  RESULTS_DIR_ADDITIONAL = Path(RESULTS_DIR) / 'additional'

  num_cores = cpu_count()

  batches = [
    (run_clock, CLOCK_BATCH_RUNS),
    (run_ancestral, [("parsimony", None, *args) for args in ANCESTRAL_BATCH_RUNS]),
    (run_ancestral, [("marginal", "sparse", *args) for args in ANCESTRAL_BATCH_RUNS]),
    (run_ancestral, [("marginal", "dense", *args) for args in ANCESTRAL_BATCH_RUNS]),
    (run_mugration, MUGRATION_BATCH_RUNS),
    (run_optimize, [("false", *args) for args in OPTIMIZE_BATCH_RUNS]),
    # (run_optimize, [("true", *args) for args in OPTIMIZE_BATCH_RUNS]), # TODO: enable optimize dense tests
    (run_prune, PRUNE_BATCH_RUNS),
    (run_timetree, TIMETREE_BATCH_RUNS),
    (run_additional_cmd, make_additional_commands(TREETIME_BIN, DATA_DIR, RESULTS_DIR_ADDITIONAL))
  ]

  start_time = time.perf_counter()
  with Pool(processes=num_cores, initializer=init_worker) as pool:
    try:
      results = [pool.starmap_async(func, args) for func, args in batches]
      results = [code for result in results for code in result.get()]
      wall_time = time.perf_counter() - start_time
      print_summary(results, wall_time, num_cores, skip_perf=no_stats)
    except KeyboardInterrupt:
      pool.terminate()
      pool.close()
    finally:
      pool.close()
      pool.join()

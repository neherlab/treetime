#!/usr/bin/env bash
set -euo pipefail
trap "exit" INT
# shellcheck source=./lib/utils.sh
source "${BASH_SOURCE%/*}/lib/utils.sh"

declare -A ALIASES=(
  ["b"]="build"
  ["br"]="build-release"
  ["bp"]="build-profiling"
  ["r"]="run"
  ["rr"]="run-release"
  ["t"]="test-all"
  ["tu"]="test-unit"
  ["ti"]="test-integration"
  ["tl"]="test-list"
  ["l"]="lint"
  ["lf"]="lint-fix"
  ["lc"]="lint-ci"
  ["lD"]="lint-deps"
  ["f"]="format"
  ["fc"]="format-check"
  ["q"]="quality"
  ["B"]="bench-all"
  ["Bd"]="bench-debug"
  ["E"]="example"
  ["Er"]="example-release"
  ["U"]="upgrade-deps"
  ["cov"]="coverage"
  ["cl"]="coverage-lcov"
  ["w"]="why"
  ["D"]="docs"
  ["L"]="list"
  ["d"]="desktop-start"
  ["db"]="desktop-build"
  ["a"]="app-start"
  ["ab"]="app-build"
  ["ar"]="app-release"
  ["arw"]="app-release-watch"
  ["jl"]="js-lint"
  ["jlf"]="js-lint-fix"
  ["jf"]="js-format"
  ["jfc"]="js-format-check"
  ["jc"]="js-check"
  ["jt"]="js-test"
  ["ji"]="js-install"
  ["ju"]="js-upgrade"
)

_CI_ARGS=()
if [ "$("$(project_root)/dev/is-ci")" == "1" ]; then
  _CI_ARGS+=("--locked")
fi

_BUILD_DIR="$(get_build_dir)"
_TEST_DIR="$(get_test_dir)"
_BUILD_RUSTFLAGS="-C linker-features=-lld ${RUSTFLAGS:-}"
_TEST_RUSTFLAGS="${HOSTCC:+-C linker=${HOSTCC}} -C link-arg=-pthread -C link-arg=-lopenblas -C link-arg=-lgfortran -C link-arg=-static-libgfortran -C link-arg=-static-libgcc -C link-arg=-static-libstdc++ ${RUSTFLAGS:-}"
_BUILD_ENV=(env "CARGO_TARGET_DIR=${_BUILD_DIR}" "RUSTFLAGS=${_BUILD_RUSTFLAGS}")
_TEST_ENV=(env "CARGO_TARGET_DIR=${_TEST_DIR}" "RUSTFLAGS=${_TEST_RUSTFLAGS}")

function is_known_command() {
  local token="${1:-}"
  [[ -n "${token}" ]] || return 1
  [[ -n "${ALIASES[$token]:-}" ]] && return 0
  for full in "${ALIASES[@]}"; do
    [[ "${full}" == "${token}" ]] && return 0
  done
  return 1
}

function show_usage() {
  local commands_list
  commands_list="$(for alias in "${!ALIASES[@]}"; do printf ' - %s (%s)\n' "${ALIASES[$alias]}" "${alias}"; done | sort)"
  printf "Usage: %s <command> [args...]\n\nMultiple commands run in sequence:\n  %s l t          # lint, then test\n  %s lf f t       # lint-fix, format, test\n\nAvailable commands:\n%s\n" "${0##*/}" "${0##*/}" "${0##*/}" "${commands_list}" >&2
}

function bun_run() {
  run_one js-install
  pushd "$(project_root)" >/dev/null
  bun run "$@"
  popd >/dev/null
}

function main() {
  declare -x RUST_BACKTRACE="${RUST_BACKTRACE:-full}"

  if [[ $# -eq 0 ]]; then
    show_usage
    exit 1
  fi

  if ! is_known_command "${1}"; then
    printf "Error: Unknown command '%s'\n\n" "${1}" >&2
    show_usage
    exit 1
  fi

  local -a cmd_groups=()
  local current=""
  for arg in "$@"; do
    if is_known_command "${arg}"; then
      [[ -n "${current}" ]] && cmd_groups+=("${current}")
      current="${arg}"
    else
      current+=$'\x1f'"${arg}"
    fi
  done
  [[ -n "${current}" ]] && cmd_groups+=("${current}")

  for group in "${cmd_groups[@]}"; do
    IFS=$'\x1f' read -r -a parts <<< "${group}"
    run_one "${parts[@]}"
  done
}

function run_one() {
  local cmd="${1:-}"
  shift || true

  [[ -n "${cmd}" && -n "${ALIASES[$cmd]:-}" ]] && cmd="${ALIASES[$cmd]}"

  # shfmt:off
  case "${cmd}" in
  "build")
    nicely "${_BUILD_ENV[@]}" cargo -q build "${_CI_ARGS[@]}" "$@"
    ;;
  "build-release")
    local bin="${1:-}"
    shift || true
    nicely "${_BUILD_ENV[@]}" cargo -q build --release "${_CI_ARGS[@]}" ${bin:+--bin="${bin}"} "$@"
    if [ -n "${bin}" ]; then
      copy_bin_to_out "${bin}"
    fi
    ;;
  "build-profiling")
    local bin="${1:-}"
    shift || true
    nicely "${_BUILD_ENV[@]}" cargo -q build --profile=profiling "${_CI_ARGS[@]}" ${bin:+--bin="${bin}"} "$@"
    ;;
  "run")
    local bin="${1:-}"
    if [[ -z "${bin}" ]]; then
      printf "Error: Binary name required for run command\n" >&2
      exit 1
    fi
    shift
    nicely "${_BUILD_ENV[@]}" cargo -q run "${_CI_ARGS[@]}" --bin "${bin}" "$@"
    ;;
  "run-release")
    local bin="${1:-}"
    if [[ -z "${bin}" ]]; then
      printf "Error: Binary name required for run-release command\n" >&2
      exit 1
    fi
    shift
    nicely "${_BUILD_ENV[@]}" cargo -q run --release "${_CI_ARGS[@]}" --bin "${bin}" "$@"
    ;;
  "example")
    local example="${1:-}"
    if [[ -z "$example" ]]; then
      printf "Error: Example name required\n" >&2
      exit 1
    fi
    shift
    nicely "${_BUILD_ENV[@]}" cargo -q run "${_CI_ARGS[@]}" --example "${example}" "$@"
    ;;
  "example-release")
    local example="${1:-}"
    if [[ -z "$example" ]]; then
      printf "Error: Example name required\n" >&2
      exit 1
    fi
    shift
    nicely "${_BUILD_ENV[@]}" cargo -q run --release "${_CI_ARGS[@]}" --example "${example}" "$@"
    ;;
  "test-all")
    nicely "${_TEST_ENV[@]}" cargo -q nextest run "${_CI_ARGS[@]}" --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "test-unit")
    nicely "${_TEST_ENV[@]}" cargo -q nextest run --lib "${_CI_ARGS[@]}" --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "test-integration")
    nicely "${_TEST_ENV[@]}" cargo -q nextest run --test='*' "${_CI_ARGS[@]}" --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "test-list")
    local pretty_args=()
    local cargo_args=()
    while (( $# > 0 )); do
      case "${1}" in
        --summary|--summary=*) pretty_args+=("${1}"); shift ;;
        --filter=*) pretty_args+=("${1}"); shift ;;
        --) shift; break ;;
        -*) cargo_args+=("${1}"); shift ;;
        *) pretty_args+=("${1}"); shift ;;
      esac
    done
    cargo_args+=("$@")
    "${_TEST_ENV[@]}" cargo -q nextest list "${_CI_ARGS[@]}" --workspace --cargo-quiet "${cargo_args[@]}" |
      "$(project_root)/dev/prettytestlist" "${pretty_args[@]}"
    ;;
  "coverage")
    local cov_dir
    cov_dir="$(project_root)/tmp/coverage"
    mkdir -p "${cov_dir}"
    nicely "${_TEST_ENV[@]}" cargo llvm-cov nextest --html --output-dir "${cov_dir}" --ignore-run-fail "${_CI_ARGS[@]}" --workspace --hide-progress-bar --color=always "$@"
    printf "Coverage report: %s/index.html\n" "${cov_dir}"
    ;;
  "coverage-lcov")
    local cov_dir
    cov_dir="$(project_root)/tmp/coverage"
    mkdir -p "${cov_dir}"
    nicely "${_TEST_ENV[@]}" cargo llvm-cov nextest --lcov --output-path "${cov_dir}/lcov.info" --ignore-run-fail "${_CI_ARGS[@]}" --workspace --hide-progress-bar --color=always "$@"
    printf "LCOV: %s/lcov.info\n" "${cov_dir}"
    ;;
  "lint")
    nicely "${_BUILD_ENV[@]}" cargo -q clippy -q --all-targets --all "${_CI_ARGS[@]}" "$@"
    ;;
  "lint-fix")
    local vcs_flag="--allow-staged"
    if [[ -f "$(project_root)/.git" ]]; then
      vcs_flag="--allow-no-vcs"
    fi
    nicely "${_BUILD_ENV[@]}" cargo -q clippy -q --all-targets --all --fix ${vcs_flag} "${_CI_ARGS[@]}" "$@"
    ;;
  "lint-ci")
    nicely "${_BUILD_ENV[@]}" cargo -q clippy -q --all-targets --all "${_CI_ARGS[@]}" -- -Dwarnings "$@"
    ;;
  "lint-deps")
    nicely cargo shear "$@"
    ;;
  "format")
    nicely cargo -q fmt "$@"
    ;;
  "format-check")
    nicely cargo -q fmt --check "$@"
    ;;
  "bench-all")
    nicely "${_BUILD_ENV[@]}" cargo -q bench --workspace --benches "${_CI_ARGS[@]}" "$@"
    ;;
  "bench-debug")
    nicely "${_BUILD_ENV[@]}" cargo -q bench --workspace --benches --profile=profiling "${_CI_ARGS[@]}" "$@"
    ;;
  "upgrade-deps")
    nicely cargo -q upgrade --pinned --incompatible --verbose --recursive "${_CI_ARGS[@]}" "$@"
    ;;
  "quality")
    run_one lint-fix "$@" && run_one format && run_one test-all "$@"
    ;;
  "why")
    nicely cargo -q tree -i -p "${_CI_ARGS[@]}" "$@"
    ;;
  "list")
    local filter="${1:-bin,example,test,bench}"
    cargo metadata --format-version=1 --no-deps 2>/dev/null |
      python3 -c "
import json, sys
data = json.load(sys.stdin)
kinds = set('${filter}'.split(','))
targets = []
for pkg in data['packages']:
    for t in pkg['targets']:
        if any(k in kinds for k in t['kind']):
            targets.append((t['kind'][0], t['name']))
for kind, name in sorted(targets):
    print(f'{kind:<8} {name}')
"
    ;;
  "docs")
    run_one build "$@"
    local bin_path="${_BUILD_DIR}/debug/treetime"
    "$(project_root)/docs/generate-reference-docs" "${bin_path}" "$(project_root)/docs/docs/reference.md"
    printf "Generated: docs/docs/reference.md\n"
    ;;
  "js-install")
    pushd "$(project_root)" >/dev/null
    bun install "$@"
    if [[ ! -f "node_modules/electron/dist/electron" ]]; then
      local electron_zip
      electron_zip="$(find .cache/electron -maxdepth 1 -name 'electron-v*-linux-x64.zip' -print -quit 2>/dev/null)"
      if [[ -n "${electron_zip}" ]]; then
        mkdir -p "node_modules/electron/dist"
        unzip -qo "${electron_zip}" -d "node_modules/electron/dist"
        printf "dist" > "node_modules/electron/path.txt"
      fi
    fi
    popd >/dev/null
    ;;
  "desktop-start")  bun_run dev:desktop "$@" ;;
  "desktop-build")  bun_run build:desktop "$@" ;;
  "app-start")      bun_run dev:web "$@" ;;
  "app-build")      bun_run build:web "$@" ;;
  "app-release")    bun_run release:web "$@" ;;
  "app-release-watch") bun_run release:web "$@" ;;
  "js-lint")        bun_run lint "$@" ;;
  "js-lint-fix")    bun_run lint:fix "$@" ;;
  "js-format")      bun_run format "$@" ;;
  "js-format-check") bun_run format:check "$@" ;;
  "js-check")       bun_run typecheck "$@" ;;
  "js-test")        bun_run test "$@" ;;
  "js-upgrade")
    pushd "$(project_root)" >/dev/null
    bun update --latest "$@"
    popd >/dev/null
    ;;
  *)
    printf "Error: Unknown command '%s'\n\n" "${cmd}" >&2
    show_usage
    exit 1
    ;;
  esac
  # shfmt:on
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi

#!/usr/bin/env bash
set -euo pipefail
trap "exit" INT
# shellcheck source=./lib/utils.sh
source "${BASH_SOURCE%/*}/lib/utils.sh"

declare -A ALIASES=(
  ["b"]="build"
  ["br"]="build-release"
  ["r"]="run"
  ["rr"]="run-release"
  ["t"]="test-all"
  ["tu"]="test-unit"
  ["ti"]="test-integration"
  ["l"]="lint"
  ["lf"]="lint-fix"
  ["lc"]="lint-ci"
  ["f"]="format"
  ["fc"]="format-check"
  ["q"]="quality"
  ["B"]="bench-all"
  ["Bd"]="bench-debug"
  ["E"]="example"
  ["Er"]="example-release"
  ["U"]="upgrade-deps"
  ["w"]="why"
  ["L"]="list"
)

function main() {
  declare -x RUST_BACKTRACE="${RUST_BACKTRACE:-full}"

  local cmd="${1:-}"
  shift || true

  # Resolve alias
  if [[ -n "${cmd}" && -n "${ALIASES[$cmd]:-}" ]]; then
    cmd="${ALIASES[$cmd]}"
  fi

  # Common setup
  local target_dir
  local test_target_dir
  target_dir="$(get_build_dir)"
  test_target_dir="$(get_test_dir)"
  local ci_flag=""
  if [ "$("$(project_root)/dev/is-ci")" == "1" ]; then
    ci_flag="--locked"
  fi

  local test_rustflags="${HOSTCC:+-C linker=${HOSTCC}} -C link-arg=-pthread -C link-arg=-lopenblas -C link-arg=-lgfortran -C link-arg=-static-libgfortran -C link-arg=-static-libgcc -C link-arg=-static-libstdc++ ${RUSTFLAGS:-}"
  local build_rustflags="-C linker-features=-lld ${RUSTFLAGS:-}"

  case "${cmd}" in
  "")
    local commands_list
    commands_list="$(for alias in "${!ALIASES[@]}"; do printf ' - %s (%s)\n' "${ALIASES[$alias]}" "${alias}"; done | sort)"
    printf "Usage: %s <command> [args...]\n\nAvailable commands:\n%s\n" "${0##*/}" "${commands_list}" >&2
    exit 1
    ;;
  "build")
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q build ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "build-release")
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q build --release ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "run")
    local bin="${1:-}"
    if [[ -z "$bin" ]]; then
      echo "Error: Binary name required for run command"
      exit 1
    fi
    shift
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q run ${ci_flag} --target-dir="${target_dir}" --bin "${bin}" "$@"
    ;;
  "run-release")
    local bin="${1:-}"
    if [[ -z "$bin" ]]; then
      echo "Error: Binary name required for run-release command"
      exit 1
    fi
    shift
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q run --release ${ci_flag} --target-dir="${target_dir}" --bin "${bin}" "$@"
    ;;
  "example")
    local example="${1:-}"
    if [[ -z "$example" ]]; then
      echo "Error: Example name required"
      exit 1
    fi
    shift
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q run ${ci_flag} --target-dir="${target_dir}" --example "${example}" "$@"
    ;;
  "example-release")
    local example="${1:-}"
    if [[ -z "$example" ]]; then
      echo "Error: Example name required"
      exit 1
    fi
    shift
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q run --release ${ci_flag} --target-dir="${target_dir}" --example "${example}" "$@"
    ;;
  "test-all")
    declare -x RUSTFLAGS="${test_rustflags}"
    nicely cargo -q nextest run ${ci_flag} --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always --target-dir="${test_target_dir}" "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "test-unit")
    declare -x RUSTFLAGS="${test_rustflags}"
    nicely cargo -q nextest run --lib ${ci_flag} --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always --target-dir="${test_target_dir}" "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "test-integration")
    declare -x RUSTFLAGS="${test_rustflags}"
    nicely cargo -q nextest run --test='*' ${ci_flag} --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always --target-dir="${test_target_dir}" "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "lint")
    nicely cargo -q clippy -q --all-targets --all ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "lint-fix")
    nicely cargo -q clippy -q --all-targets --all --fix --allow-staged ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "lint-ci")
    nicely cargo -q clippy --all-targets --all ${ci_flag} --target-dir="${target_dir}" -- -Dwarnings "$@"
    ;;
  "format")
    nicely cargo -q fmt "$@"
    ;;
  "format-check")
    nicely cargo -q fmt --check "$@"
    ;;
  "bench-all")
    nicely cargo -q bench --workspace --benches ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "bench-debug")
    nicely cargo -q bench --workspace --benches --profile=profiling ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "upgrade-deps")
    declare -x CARGO_NET_GIT_FETCH_WITH_CLI=true
    declare -x CARGO_REGISTRIES_CRATES_IO_PROTOCOL='git'
    declare -x CARGO_REGISTRIES_CRATES_IO_PROTOCOL='git cargo fetch'
    declare -x CARGO_REGISTRIES_CRATES_IO_PROTOCOL='git cargo upgrade'
    nicely cargo -q upgrade --pinned --incompatible --verbose --recursive ${ci_flag} "$@"
    ;;
  "quality")
    "${BASH_SOURCE[0]}" lint-fix "$@" && "${BASH_SOURCE[0]}" format "$@" && "${BASH_SOURCE[0]}" test-all "$@"
    ;;
  "why")
    nicely cargo -q tree -i -p ${ci_flag} "$@"
    ;;
  "list")
    local filter="${1:-bin,example,test,bench}"
    cargo metadata --format-version=1 --no-deps 2>/dev/null |
      python3 -c "
import json, sys
data = json.load(sys.stdin)
kinds = set('${filter}'.split(','))
targets = []
for pkg in data['packages']:
    for t in pkg['targets']:
        if any(k in kinds for k in t['kind']):
            targets.append((t['kind'][0], t['name']))
for kind, name in sorted(targets):
    print(f'{kind:<8} {name}')
"
    ;;
  *)
    local commands_list
    commands_list="$(for alias in "${!ALIASES[@]}"; do printf ' - %s (%s)\n' "${ALIASES[$alias]}" "${alias}"; done | sort)"
    printf "Error: Unknown command '%s'\n\nAvailable commands:\n%s\n" "${cmd}" "${commands_list}" >&2
    exit 1
    ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi

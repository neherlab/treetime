#!/usr/bin/env bash
set -euo pipefail
trap "exit" INT
# shellcheck source=./lib/utils.sh
source "${BASH_SOURCE%/*}/lib/utils.sh"

declare -A ALIASES=(
  ["b"]="build"
  ["br"]="build-release"
  ["bp"]="build-profiling"
  ["r"]="run"
  ["rr"]="run-release"
  ["t"]="test-all"
  ["tu"]="test-unit"
  ["ti"]="test-integration"
  ["tl"]="test-list"
  ["l"]="lint"
  ["lf"]="lint-fix"
  ["lc"]="lint-ci"
  ["lD"]="lint-deps"
  ["f"]="format"
  ["fc"]="format-check"
  ["q"]="quality"
  ["B"]="bench-all"
  ["Bd"]="bench-debug"
  ["E"]="example"
  ["Er"]="example-release"
  ["U"]="upgrade-deps"
  ["cov"]="coverage"
  ["cl"]="coverage-lcov"
  ["w"]="why"
  ["L"]="list"
  ["db"]="desktop-build"
  ["df"]="desktop-frontend"
  ["ds"]="desktop-start"
)

function is_known_command() {
  local token="${1:-}"
  [[ -n "${token}" ]] || return 1
  [[ -n "${ALIASES[$token]:-}" ]] && return 0
  for full in "${ALIASES[@]}"; do
    [[ "${full}" == "${token}" ]] && return 0
  done
  return 1
}

function show_usage() {
  local commands_list
  commands_list="$(for alias in "${!ALIASES[@]}"; do printf ' - %s (%s)\n' "${ALIASES[$alias]}" "${alias}"; done | sort)"
  printf "Usage: %s <command> [args...]\n\nMultiple commands run in sequence:\n  %s l t          # lint, then test\n  %s lf f t       # lint-fix, format, test\n\nAvailable commands:\n%s\n" "${0##*/}" "${0##*/}" "${0##*/}" "${commands_list}" >&2
}

function main() {
  declare -x RUST_BACKTRACE="${RUST_BACKTRACE:-full}"

  if [[ $# -eq 0 ]]; then
    show_usage
    exit 1
  fi

  if ! is_known_command "${1}"; then
    printf "Error: Unknown command '%s'\n\n" "${1}" >&2
    show_usage
    exit 1
  fi

  # Split args into command groups at each recognized command/alias boundary.
  # Each known command starts a new group; non-command tokens are args to the preceding group.
  local -a cmd_groups=()
  local current=""
  for arg in "$@"; do
    if is_known_command "${arg}"; then
      [[ -n "${current}" ]] && cmd_groups+=("${current}")
      current="${arg}"
    else
      current+=$'\x1f'"${arg}"
    fi
  done
  [[ -n "${current}" ]] && cmd_groups+=("${current}")

  for group in "${cmd_groups[@]}"; do
    IFS=$'\x1f' read -r -a parts <<< "${group}"
    run_one "${parts[@]}"
  done
}

function run_one() {
  local cmd="${1:-}"
  shift || true

  # Resolve alias
  if [[ -n "${cmd}" && -n "${ALIASES[$cmd]:-}" ]]; then
    cmd="${ALIASES[$cmd]}"
  fi

  # Common setup
  local target_dir
  local test_target_dir
  target_dir="$(get_build_dir)"
  test_target_dir="$(get_test_dir)"
  local ci_flag=""
  if [ "$("$(project_root)/dev/is-ci")" == "1" ]; then
    ci_flag="--locked"
  fi

  local test_rustflags="${HOSTCC:+-C linker=${HOSTCC}} -C link-arg=-pthread -C link-arg=-lopenblas -C link-arg=-lgfortran -C link-arg=-static-libgfortran -C link-arg=-static-libgcc -C link-arg=-static-libstdc++ ${RUSTFLAGS:-}"
  local build_rustflags="-C linker-features=-lld ${RUSTFLAGS:-}"

  case "${cmd}" in
  "build")
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q build ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "build-release")
    local bin="${1:-}"
    shift || true
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q build --release ${ci_flag} --target-dir="${target_dir}" ${bin:+--bin="${bin}"} "$@"
    if [ -n "${bin}" ]; then
      copy_bin_to_out "${bin}"
    fi
    ;;
  "build-profiling")
    local bin="${1:-}"
    shift || true
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q build --profile=profiling ${ci_flag} --target-dir="${target_dir}" ${bin:+--bin="${bin}"} "$@"
    ;;
  "run")
    local bin="${1:-}"
    if [[ -z "$bin" ]]; then
      echo "Error: Binary name required for run command"
      exit 1
    fi
    shift
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q run ${ci_flag} --target-dir="${target_dir}" --bin "${bin}" "$@"
    ;;
  "run-release")
    local bin="${1:-}"
    if [[ -z "$bin" ]]; then
      echo "Error: Binary name required for run-release command"
      exit 1
    fi
    shift
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q run --release ${ci_flag} --target-dir="${target_dir}" --bin "${bin}" "$@"
    ;;
  "example")
    local example="${1:-}"
    if [[ -z "$example" ]]; then
      echo "Error: Example name required"
      exit 1
    fi
    shift
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q run ${ci_flag} --target-dir="${target_dir}" --example "${example}" "$@"
    ;;
  "example-release")
    local example="${1:-}"
    if [[ -z "$example" ]]; then
      echo "Error: Example name required"
      exit 1
    fi
    shift
    declare -x RUSTFLAGS="${build_rustflags}"
    nicely cargo -q run --release ${ci_flag} --target-dir="${target_dir}" --example "${example}" "$@"
    ;;
  "test-all")
    declare -x RUSTFLAGS="${test_rustflags}"
    nicely cargo -q nextest run ${ci_flag} --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always --target-dir="${test_target_dir}" "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "test-unit")
    declare -x RUSTFLAGS="${test_rustflags}"
    nicely cargo -q nextest run --lib ${ci_flag} --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always --target-dir="${test_target_dir}" "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "test-integration")
    declare -x RUSTFLAGS="${test_rustflags}"
    nicely cargo -q nextest run --test='*' ${ci_flag} --success-output=immediate --workspace --cargo-quiet --no-fail-fast --hide-progress-bar --color=always --target-dir="${test_target_dir}" "$@" 2>&1 |
      "$(project_root)/dev/prettytest"
    ;;
  "coverage")
    declare -x RUSTFLAGS="${test_rustflags}"
    declare -x CARGO_TARGET_DIR="${test_target_dir}"
    local cov_dir
    cov_dir="$(project_root)/tmp/coverage"
    mkdir -p "${cov_dir}"
    nicely cargo llvm-cov nextest --html --output-dir "${cov_dir}" --ignore-run-fail ${ci_flag} --workspace --hide-progress-bar --color=always "$@"
    printf "Coverage report: %s/index.html\n" "${cov_dir}"
    ;;
  "coverage-lcov")
    declare -x RUSTFLAGS="${test_rustflags}"
    declare -x CARGO_TARGET_DIR="${test_target_dir}"
    local cov_dir
    cov_dir="$(project_root)/tmp/coverage"
    mkdir -p "${cov_dir}"
    nicely cargo llvm-cov nextest --lcov --output-path "${cov_dir}/lcov.info" --ignore-run-fail ${ci_flag} --workspace --hide-progress-bar --color=always "$@"
    printf "LCOV: %s/lcov.info\n" "${cov_dir}"
    ;;
  "lint")
    nicely cargo -q clippy -q --all-targets --all ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "lint-fix")
    local vcs_flag="--allow-staged"
    if [[ -f "$(project_root)/.git" ]]; then
      vcs_flag="--allow-no-vcs"
    fi
    nicely cargo -q clippy -q --all-targets --all --fix ${vcs_flag} ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "lint-ci")
    nicely cargo -q clippy -q --all-targets --all ${ci_flag} --target-dir="${target_dir}" -- -Dwarnings "$@"
    ;;
  "lint-deps")
    nicely cargo shear "$@"
    ;;
  "format")
    nicely cargo -q fmt "$@"
    ;;
  "format-check")
    nicely cargo -q fmt --check "$@"
    ;;
  "bench-all")
    nicely cargo -q bench --workspace --benches ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "bench-debug")
    nicely cargo -q bench --workspace --benches --profile=profiling ${ci_flag} --target-dir="${target_dir}" "$@"
    ;;
  "upgrade-deps")
    nicely cargo -q upgrade --pinned --incompatible --verbose --recursive ${ci_flag} "$@"
    ;;
  "quality")
    run_one lint-fix "$@" && run_one format "$@" && run_one test-all "$@"
    ;;
  "why")
    nicely cargo -q tree -i -p ${ci_flag} "$@"
    ;;
  "list")
    local filter="${1:-bin,example,test,bench}"
    cargo metadata --format-version=1 --no-deps 2>/dev/null |
      python3 -c "
import json, sys
data = json.load(sys.stdin)
kinds = set('${filter}'.split(','))
targets = []
for pkg in data['packages']:
    for t in pkg['targets']:
        if any(k in kinds for k in t['kind']):
            targets.append((t['kind'][0], t['name']))
for kind, name in sorted(targets):
    print(f'{kind:<8} {name}')
"
    ;;
  "test-list")
    declare -x RUSTFLAGS="${test_rustflags}"
    local pretty_args=()
    local cargo_args=()
    while (( $# > 0 )); do
      case "${1}" in
        --summary|--summary=*) pretty_args+=("${1}"); shift ;;
        --filter=*) pretty_args+=("${1}"); shift ;;
        --) shift; break ;;
        -*) cargo_args+=("${1}"); shift ;;
        *) pretty_args+=("${1}"); shift ;;
      esac
    done
    cargo_args+=("$@")
    cargo -q nextest list ${ci_flag} --workspace --cargo-quiet --target-dir="${test_target_dir}" "${cargo_args[@]}" |
      "$(project_root)/dev/prettytestlist" "${pretty_args[@]}"
    ;;
  "desktop-build")
    local desktop_dir
    desktop_dir="$(project_root)/packages/app-napi"
    pushd "${desktop_dir}" >/dev/null
    npm run build "$@"
    popd >/dev/null
    ;;
  "desktop-frontend")
    declare -x electron_config_cache="$(project_root)/.cache/electron"
    declare -x npm_config_cache="$(project_root)/.cache/npm"
    local frontend_dir
    frontend_dir="$(project_root)/packages/app-desktop"
    pushd "${frontend_dir}" >/dev/null
    npm install "$@"
    popd >/dev/null
    ;;
  "desktop-start")
    declare -x electron_config_cache="$(project_root)/.cache/electron"
    local frontend_dir
    frontend_dir="$(project_root)/packages/app-desktop"
    pushd "${frontend_dir}" >/dev/null
    npm start "$@"
    popd >/dev/null
    ;;
  *)
    printf "Error: Unknown command '%s'\n\n" "${cmd}" >&2
    show_usage
    exit 1
    ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi

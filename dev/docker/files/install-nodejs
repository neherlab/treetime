#!/usr/bin/env bash
set -euxo pipefail

node_version="24.16.0"
node_dir="/opt/node"
bun_version="1.3.14"
bun_dir="/opt/bun"
bin_dir="/usr/local/bin"

mkdir -p "${node_dir}" "${bun_dir}" "${bin_dir}"

curl -fsSL "https://nodejs.org/dist/v${node_version}/node-v${node_version}-linux-x64.tar.xz" \
  | tar -xJ --strip-components=1 -C "${node_dir}"
ln -sf "${node_dir}/bin/node" "${bin_dir}/node"
ln -sf "${node_dir}/bin/npm" "${bin_dir}/npm"
ln -sf "${node_dir}/bin/npx" "${bin_dir}/npx"

curl -fsSLo "/tmp/bun.zip" "https://github.com/oven-sh/bun/releases/download/bun-v${bun_version}/bun-linux-x64.zip"
unzip -q "/tmp/bun.zip" -d "/tmp/bun-extract"
mv "/tmp/bun-extract/bun-linux-x64/bun" "${bun_dir}/bun"
chmod +x "${bun_dir}/bun"
ln -sf "${bun_dir}/bun" "${bin_dir}/bun"
ln -sf "${bun_dir}/bun" "${bin_dir}/bunx"
rm -rf "/tmp/bun.zip" "/tmp/bun-extract"

node --version
bun --version

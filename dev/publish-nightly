#!/usr/bin/env bash
#
# Usage: $0 [options]
#
# Upload CLI artifacts as a nightly prerelease in the release repository.
# The release tag combines the workspace version and supplied nightly suffix.
#
# Options:
#   -h, --help                     Show this help
#   --artifacts_dir <dir>          Directory containing build artifacts
#   --source_repo <owner/repo>     GitHub repository containing the source
#   --release_repo <owner/repo>    GitHub repository receiving the release
#   --git_sha <sha>                Source commit SHA
#   --version_suffix <suffix>      Nightly version suffix
#
# Environment:
#   GITHUB_TOKEN    GitHub token with contents:write for the release repository.
#
set -euo pipefail
trap "exit" INT

generate_release_notes() {
  local repo="${1}"
  local git_sha="${2}"
  local short_sha="${3}"

  cat <<EOF
Nightly pre-release build of [treetime](https://github.com/${repo}).

**Source**: [\`${short_sha}\`](https://github.com/${repo}/commit/${git_sha})

> [!WARNING]
> Automated nightly build for early testing. May contain bugs and breaking changes.
EOF
}

main() {
  show_help() {
    sed -n '2,${/^#/!q; s/^# \?//p}' "${BASH_SOURCE[0]}" | sed "s|\$0|${0##*/}|g"
  }

  local artifacts_dir=""
  local source_repo=""
  local release_repo=""
  local git_sha=""
  local version_suffix=""

  # shfmt:off
  while (( $# > 0 )); do
    case "${1}" in
      -h|--help) show_help; exit 0 ;;
      --artifacts_dir) artifacts_dir="${2}"; shift 2 ;;
      --source_repo) source_repo="${2}"; shift 2 ;;
      --release_repo) release_repo="${2}"; shift 2 ;;
      --git_sha) git_sha="${2}"; shift 2 ;;
      --version_suffix) version_suffix="${2}"; shift 2 ;;
      --) shift; break ;;
      -*) printf "Unknown option: %s\n" "${1}" >&2; exit 1 ;;
      *) break ;;
    esac
  done
  # shfmt:on

  local dependency
  for dependency in gh yq; do
    command -v "${dependency}" >/dev/null || { printf "Required command not found: %s\n" "${dependency}" >&2; exit 1; }
  done
  : "${GITHUB_TOKEN:?GITHUB_TOKEN is required}"
  [[ -d "${artifacts_dir}" ]] || { printf "Artifact directory does not exist: %s\n" "${artifacts_dir}" >&2; exit 1; }
  [[ -n "${source_repo}" ]] || { printf "--source_repo is required\n" >&2; exit 1; }
  [[ -n "${release_repo}" ]] || { printf "--release_repo is required\n" >&2; exit 1; }
  [[ -n "${git_sha}" ]] || { printf "--git_sha is required\n" >&2; exit 1; }
  [[ -n "${version_suffix}" ]] || { printf "--version_suffix is required\n" >&2; exit 1; }

  local artifacts=()
  local artifact
  for artifact in "${artifacts_dir}"/*; do
    [[ -f "${artifact}" ]] && artifacts+=("${artifact}")
  done
  (( ${#artifacts[@]} > 0 )) || { printf "No artifacts found in: %s\n" "${artifacts_dir}" >&2; exit 1; }

  local binary="${artifacts_dir}/treetime-x86_64-unknown-linux-gnu"
  [[ -f "${binary}" ]] || { printf "Required Linux artifact not found: %s\n" "${binary}" >&2; exit 1; }

  local cargo_version
  cargo_version=$(yq -r '.workspace.package.version' Cargo.toml)
  local version="${cargo_version}-${version_suffix}"
  local short_sha="${git_sha:0:7}"

  printf "Creating nightly release: %s\n" "${version}"
  generate_release_notes "${source_repo}" "${git_sha}" "${short_sha}" |
    gh release create "${version}" \
      --repo "${release_repo}" \
      --title "${version}" \
      --prerelease \
      --notes-file - \
      "${artifacts[@]}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi

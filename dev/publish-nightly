#!/usr/bin/env bash
#
# Usage: $0 [options]
#
# Upload CLI artifacts as a nightly release in the release repository.
# The release tag combines the workspace version and supplied nightly suffix.
#
# Options:
#   -h, --help                     Show this help
#   --artifacts_dir <dir>          Directory containing build artifacts
#   --source_repo <owner/repo>     GitHub repository containing the source
#   --release_repo <owner/repo>    GitHub repository receiving the release
#   --git_sha <sha>                Source commit SHA
#   --version_suffix <suffix>      Nightly version suffix
#
# Environment:
#   GITHUB_TOKEN    GitHub token with contents:write for the release repository.
#
set -euo pipefail
trap "exit" INT

# Resolve the source commit of the most recent published nightly, used as the
# lower bound of the changelog. Always succeeds: on any lookup or resolution
# failure it prints nothing so the caller falls back to notes without a
# changelog rather than aborting the publication.
find_last_nightly_sha() {
  local repo="${1}"

  local last_tag
  last_tag=$(gh release list --repo "${repo}" --exclude-drafts --limit 100 --json tagName \
    --jq '[.[] | select(.tagName | contains("-nightly."))][0].tagName // ""' 2>/dev/null) || return 0
  [[ -n "${last_tag}" ]] || return 0

  local abbreviated_sha="${last_tag##*+}"
  [[ "${abbreviated_sha}" != "${last_tag}" ]] || return 0

  local resolved
  resolved=$(git rev-parse --verify --quiet "${abbreviated_sha}^{commit}" 2>/dev/null) || {
    printf "Unable to resolve previous nightly source: %s\n" "${abbreviated_sha}" >&2
    return 0
  }
  printf "%s\n" "${resolved}"
}

# Emit the release body. The base template is always produced; the changelog
# (compare link, merged pull requests, and commits landed outside any pull
# request) is appended only when the previous nightly source is known and its
# history is available. Every changelog query degrades to an empty section on
# failure so notes generation never gates publication of built artifacts.
generate_release_notes() {
  local repo="${1}"
  local git_sha="${2}"
  local short_sha="${3}"
  local last_sha="${4:-}"

  cat <<EOF
Nightly build of [treetime](https://github.com/${repo}).

**Source**: [\`${short_sha}\`](https://github.com/${repo}/commit/${git_sha})

> [!WARNING]
> Automated nightly build for early testing. May contain bugs and breaking changes.
EOF

  [[ -n "${last_sha}" ]] || return 0

  printf "\n**Compare**: [\`%s...%s\`](https://github.com/%s/compare/%s...%s)\n" \
    "${last_sha:0:7}" "${short_sha}" "${repo}" "${last_sha}" "${git_sha}"

  local last_commit_date
  last_commit_date=$(git show -s --format='%aI' "${last_sha}" 2>/dev/null) || return 0

  local pr_json
  pr_json=$(gh pr list --repo "${repo}" --state merged --base rust --limit 100 \
    --json number,title,mergeCommit,mergedAt \
    --jq "[.[] | select(.mergedAt > \"${last_commit_date}\")]" 2>/dev/null) || pr_json="[]"

  if (( $(jq 'length' <<< "${pr_json}") > 0 )); then
    printf "\n## Pull requests\n\n| PR | Title |\n|---|---|\n"
    jq -r ".[] | \"| [#\\(.number)](https://github.com/${repo}/pull/\\(.number)) | \\(.title | gsub(\"[|]\"; \"\\\\|\")) |\"" <<< "${pr_json}"
  fi

  local pr_shas
  pr_shas=$(jq -r '.[].mergeCommit.oid // empty' <<< "${pr_json}")
  local all_commits
  all_commits=$(git log --format='%H %s' "${last_sha}..${git_sha}" 2>/dev/null) || return 0

  local orphan_table=""
  local line commit_sha commit_msg
  while IFS= read -r line; do
    [[ -n "${line}" ]] || continue
    commit_sha="${line%% *}"
    commit_msg="${line#* }"
    if [[ -z "${pr_shas}" ]] || ! grep -qF "${commit_sha}" <<< "${pr_shas}"; then
      orphan_table+="| [\`${commit_sha:0:7}\`](https://github.com/${repo}/commit/${commit_sha}) | ${commit_msg//|/\\|} |"$'\n'
    fi
  done <<< "${all_commits}"

  if [[ -n "${orphan_table}" ]]; then
    printf "\n## Commits not in any PR\n\n| Commit | Message |\n|---|---|\n%s" "${orphan_table}"
  fi
}

main() {
  show_help() {
    sed -n '2,${/^#/!q; s/^# \?//p}' "${BASH_SOURCE[0]}" | sed "s|\$0|${0##*/}|g"
  }

  local artifacts_dir=""
  local source_repo=""
  local release_repo=""
  local git_sha=""
  local version_suffix=""

  # shfmt:off
  while (( $# > 0 )); do
    case "${1}" in
      -h|--help) show_help; exit 0 ;;
      --artifacts_dir) artifacts_dir="${2}"; shift 2 ;;
      --source_repo) source_repo="${2}"; shift 2 ;;
      --release_repo) release_repo="${2}"; shift 2 ;;
      --git_sha) git_sha="${2}"; shift 2 ;;
      --version_suffix) version_suffix="${2}"; shift 2 ;;
      --) shift; break ;;
      -*) printf "Unknown option: %s\n" "${1}" >&2; exit 1 ;;
      *) break ;;
    esac
  done
  # shfmt:on

  local dependency
  for dependency in gh yq git jq; do
    command -v "${dependency}" >/dev/null || { printf "Required command not found: %s\n" "${dependency}" >&2; exit 1; }
  done
  : "${GITHUB_TOKEN:?GITHUB_TOKEN is required}"
  [[ -d "${artifacts_dir}" ]] || { printf "Artifact directory does not exist: %s\n" "${artifacts_dir}" >&2; exit 1; }
  [[ -n "${source_repo}" ]] || { printf "--source_repo is required\n" >&2; exit 1; }
  [[ -n "${release_repo}" ]] || { printf "--release_repo is required\n" >&2; exit 1; }
  [[ -n "${git_sha}" ]] || { printf "--git_sha is required\n" >&2; exit 1; }
  [[ -n "${version_suffix}" ]] || { printf "--version_suffix is required\n" >&2; exit 1; }

  local artifacts=()
  local artifact
  for artifact in "${artifacts_dir}"/*; do
    [[ -f "${artifact}" ]] && artifacts+=("${artifact}")
  done
  (( ${#artifacts[@]} > 0 )) || { printf "No artifacts found in: %s\n" "${artifacts_dir}" >&2; exit 1; }

  local binary="${artifacts_dir}/treetime-x86_64-unknown-linux-gnu"
  [[ -f "${binary}" ]] || { printf "Required Linux artifact not found: %s\n" "${binary}" >&2; exit 1; }

  local cargo_version
  cargo_version=$(yq -r '.workspace.package.version' Cargo.toml)
  local version="${cargo_version}-${version_suffix}"
  local short_sha="${git_sha:0:7}"

  local last_sha
  last_sha=$(find_last_nightly_sha "${release_repo}")

  printf "Creating nightly release: %s\n" "${version}"
  generate_release_notes "${source_repo}" "${git_sha}" "${short_sha}" "${last_sha}" |
    gh release create "${version}" \
      --repo "${release_repo}" \
      --title "${version}" \
      --notes-file - \
      "${artifacts[@]}"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi

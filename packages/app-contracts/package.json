{
  "name": "@neherlab/app-contracts",
  "version": "0.0.1",
  "private": true,
  "description": "TypeScript type definitions for TreeTime bridge interface",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "oxlint": "1.66.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  }
}

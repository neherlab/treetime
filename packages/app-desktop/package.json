{
  "name": "@neherlab/app-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "TreeTime desktop application - Electron shell",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint src/ renderer/",
    "lint:fix": "oxlint --fix src/ renderer/",
    "format": "oxfmt --write src/ renderer/",
    "format:check": "oxfmt --check src/ renderer/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neherlab/app-contracts": "workspace:*",
    "@neherlab/app-napi": "workspace:*",
    "@neherlab/app-ui": "workspace:*",
    "@tailwindcss/vite": "4.3.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "electron": "42.2.0",
    "electron-builder": "26.8.1",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-electron": "0.29.1"
  },
  "build": {
    "appId": "org.neherlab.treetime",
    "productName": "TreeTime",
    "directories": {
      "output": "../../.build/desktop/release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    }
  }
}

{
  "name": "@neherlab/app-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "TreeTime desktop application - Electron shell",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && electron . --no-sandbox",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neherlab/app-contracts": "workspace:*",
    "electron": "42.2.0"
  },
  "devDependencies": {
    "oxlint": "1.66.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  }
}

{
  "name": "@neherlab/app-web",
  "version": "0.0.1",
  "private": true,
  "description": "TreeTime web application - browser frontend",
  "scripts": {
    "build": "vite build",
    "dev": "nodemon -q --exec 'bun install && vite'",
    "dev:nowatch": "vite",
    "release": "vite build --watch",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "2.0.1",
    "@neherlab/app-contracts": "workspace:*",
    "@neherlab/app-ui": "workspace:*",
    "@tailwindcss/vite": "4.3.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "nodemon": "3.1.9",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "nodemonConfig": {
    "watch": [
      "package.json",
      "../app-contracts/package.json",
      "../app-ui/package.json",
      "../../package.json",
      "../../bun.lock"
    ],
    "ext": "json,lock",
    "delay": 300
  }
}

{
  "name": "@neherlab/app-web",
  "version": "0.0.1",
  "private": true,
  "description": "TreeTime web application - browser frontend",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "release": "vite build --watch",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@neherlab/app-contracts": "workspace:*",
    "@neherlab/app-ui": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  }
}

#!/usr/bin/env python3
"""Capture v0 relative probabilities after neg-log likelihood multiplication."""

import json
import sys
from pathlib import Path

import numpy as np

PROJECT_ROOT = Path(__file__).resolve().parents[5]
FIXTURES_DIR = Path(__file__).parent
sys.path.insert(0, str(PROJECT_ROOT / "packages" / "legacy" / "treetime"))

from treetime.distribution import Distribution  # noqa: E402


def capture_case(case: dict[str, list[float]]) -> dict[str, object]:
    """Return v0's normalized shape for one likelihood product."""
    time_points = np.asarray(case["time_points"], dtype=float)
    child = Distribution(time_points, np.asarray(case["child_neglog"], dtype=float), is_log=True)
    coalescent = Distribution(time_points, np.asarray(case["coalescent_neglog"], dtype=float), is_log=True)
    product = Distribution.multiply([child, coalescent])
    return {
        "time_points": [float(value) for value in product.x],
        "probabilities_relative": [float(value) for value in product.prob_relative(product.x)],
        "peak_position": float(product.peak_pos),
    }


def main() -> None:
    """Capture every input case from the canonical v0 implementation."""
    inputs_path = FIXTURES_DIR / "gm_neglog_normalization_inputs.json"
    outputs_path = FIXTURES_DIR / "gm_neglog_normalization_outputs.json"
    with inputs_path.open() as file:
        inputs = json.load(file)
    outputs = {name: capture_case(case) for name, case in inputs.items()}
    with outputs_path.open("w") as file:
        json.dump(outputs, file, indent=2)
        file.write("\n")


if __name__ == "__main__":
    main()

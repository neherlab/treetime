{
  "name": "@neherlab/app-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Shared React components for TreeTime desktop and web apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neherlab/app-contracts": "workspace:*",
    "@tanstack/react-query": "5.100.11",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}

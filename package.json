{
  "name": "@neherlab/treetime",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/app-contracts",
    "packages/app-desktop",
    "packages/app-napi",
    "packages/app-server",
    "packages/app-ui",
    "packages/app-web"
  ],
  "scripts": {
    "dev:desktop": "turbo dev --filter=@neherlab/app-desktop",
    "dev:web": "turbo dev --filter=@neherlab/app-web --filter=@neherlab/app-server",
    "dev:server": "turbo dev --filter=@neherlab/app-server",
    "build": "turbo build",
    "build:desktop": "turbo build --filter=@neherlab/app-desktop",
    "build:web": "turbo build --filter=@neherlab/app-web --filter=@neherlab/app-server",
    "release:web": "turbo watch release --filter=@neherlab/app-web --filter=@neherlab/app-server",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "upgrade": "bun update --latest"
  },
  "devDependencies": {
    "@microsoft/fetch-event-source": "2.0.1",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "turbo": "2.9.14"
  },
  "trustedDependencies": [
    "electron"
  ]
}
